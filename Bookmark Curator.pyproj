<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003" DefaultTargets="Build">
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectGuid>{eae26600-5422-4718-8368-18f8d8897a72}</ProjectGuid>
    <ProjectHome />
    <StartupFile />
    <SearchPath />
    <WorkingDirectory>.</WorkingDirectory>
    <OutputPath>.</OutputPath>
    <ProjectTypeGuids>{888888a0-9f3d-457c-b088-3a5042f75d52}</ProjectTypeGuids>
    <LaunchProvider>Standard Python launcher</LaunchProvider>
    <InterpreterId>Global|PythonCore|3.10</InterpreterId>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'" />
  <PropertyGroup Condition="'$(Configuration)' == 'Release'" />
  <PropertyGroup>
    <VisualStudioVersion Condition=" '$(VisualStudioVersion)' == '' ">10.0</VisualStudioVersion>
  </PropertyGroup>
  <ItemGroup>
    <Content Include="docs\Choose_folders.gif" />
    <Content Include="docs\Copy_bookmarks.gif" />
    <Content Include="docs\Delete_bookmarks.gif" />
    <Content Include="docs\Export_bookmarks.gif" />
    <Content Include="docs\Import_bookmarks.gif" />
    <Content Include="docs\Open_app.gif" />
